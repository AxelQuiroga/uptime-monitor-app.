# =============================================================================
# Uptime Monitor — Configuración Local
# =============================================================================
# Copiá este archivo como .env y ajustá los valores para tu entorno local.
# NUNCA committees .env al repositorio.
#
#   cp .env.example .env
#   docker compose up -d --build
# =============================================================================

# --- Base de datos ---
DB_NAME=devopsdb
DB_USER=admin
DB_PASSWORD=secret123

# --- Flask ---
FLASK_DEBUG=1
SECRET_KEY=generá esto con: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_PASSWORD=la-contraseña-que-quieras
