# =============================================================================
# Uptime Monitor — Environment Variables
# =============================================================================
# Copy this file as .env and adjust values for your environment.
#
#   cp .env.example .env
#   docker compose up -d --build
# =============================================================================

# --- Database ---
DB_NAME=devopsdb
DB_USER=admin
DB_PASSWORD=changeme

# --- Redis (used by RQ scheduler + worker) ---
REDIS_URL=redis://redis:6439/0

# --- Flask ---
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-random-secret-32-chars-min

# --- Auth (single-password admin login) ---
ADMIN_PASSWORD=changeme
